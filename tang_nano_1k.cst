# =============================================================
# tang_nano_1k.cst  —  Physical Constraint File (Gowin)
# Board  : Sipeed Tang Nano 1K (GW1NZ-LV1)
# Tool   : Gowin EDA (GVERILOG / GowinSynthesis)
# =============================================================

# Clock — onboard 27 MHz oscillator
IO_LOC  "clk"   45;
IO_PORT "clk"   PULL_MODE=NONE IO_TYPE=LVCMOS33;

# Button — onboard BTN1, active-low with internal pull-up
IO_LOC  "btn"    3;
IO_PORT "btn"   PULL_MODE=UP   IO_TYPE=LVCMOS33;

# LED_R — anomaly (active-low)
IO_LOC  "led_r" 16;
IO_PORT "led_r" PULL_MODE=NONE IO_TYPE=LVCMOS33 DRIVE=8;

# LED_G — normal (active-low)
IO_LOC  "led_g" 17;
IO_PORT "led_g" PULL_MODE=NONE IO_TYPE=LVCMOS33 DRIVE=8;
